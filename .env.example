# Efficient Labs environment template.
# This file is safe to commit because all secret values are blank examples.

# Vercel app runtime. Production and preview need this so Next.js can proxy
# account-plan reads and Stripe webhooks to the VPS billing API.
BILLING_API_BASE_URL=https://api.efficientlabs.ai/

# Public browser config. NEXT_PUBLIC_* values are bundled client-side.
NEXT_PUBLIC_CALCOM_LINK=

# VPS billing-api secrets. Do not add these to Vercel.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_EXOS_PRO_MONTHLY=
STRIPE_PRICE_EXOS_PRO_ANNUAL=
STRIPE_PRICE_APEX_MONTHLY=
STRIPE_PRICE_APEX_ANNUAL=
STRIPE_PRICE_TEAMS_MONTHLY=
STRIPE_PRICE_TEAMS_ANNUAL=

# VPS billing-api Postgres access. Prefer local peer auth on the VPS; only set
# DATABASE_URL when the owner-controlled DB endpoint requires a connection URL.
DATABASE_URL=
PGHOST=/var/run/postgresql
PGDATABASE=efficientlabs
PGUSER=neo
POSTGRES_POOL_MAX=5
POSTGRES_SSL=

# Owner-controlled auth verifier for billing/account reads. Server-side only;
# keep these on the VPS billing-api process. Generate AUTH_TOKEN_SECRET with
# `openssl rand -base64 32` and rotate through the process manager/vault.
AUTH_VERIFIER_MODE=efficientlabs
AUTH_TOKEN_SECRET=
AUTH_TOKEN_ISSUER=https://efficientlabs.ai
AUTH_TOKEN_AUDIENCE=efficientlabs-web
AUTH_TOKEN_TTL_SECONDS=3600
AUTH_SIGNUPS_ENABLED=true
AUTH_SIGNUP_CODE=
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=20

# Legacy server fallback only while Supabase auth is being retired. To use it
# deliberately, set AUTH_VERIFIER_MODE=supabase on the billing-api process.
SUPABASE_URL=
SUPABASE_ANON_KEY=
